<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title | default("directionary") }}</title>
<meta name="description" content="{{ description | default('a small, growing dictionary. older words. newer meanings.') }}">
<link rel="alternate" type="application/rss+xml" title="directionary" href="/rss.xml">
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><text x='50%' y='50%' dominant-baseline='middle' text-anchor='middle' font-size='42'>🧭</text></svg>">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
<a class="skip-link" href="#main">skip to content</a>

<section class="hero">
  <div class="hero__heading">
    <h1 class="wordmark-large"><a href="/">directionary</a></h1>
    <p class="pronunciation">/dɪˌrɛk.ʃəˈner.i/ — noun</p>
    <p class="tagline">older words. newer meanings.</p>
  </div>

  <form class="search" id="search-form" role="search" onsubmit="return false;">
    <label class="visually-hidden" for="search-input">search words</label>
    <input id="search-input" type="search" placeholder="i'm looking for…" autocomplete="off">
    <div id="search-results" class="search-results" hidden></div>
  </form>
</section>

<main id="main" data-pagefind-body>
{{ content | safe }}
</main>

<footer class="site-footer">
  <a class="wordmark" href="/">directionary</a>
  <p>made for 🧬 with a 🧠 in their 💀</p>
  <nav class="site-nav">
    <a href="/contribute/">contribute</a>
    <a href="#" id="random-link-footer">random</a>
  </nav>
</footer>

<script src="/assets/js/random-word.js" defer></script>
<script src="/assets/js/search.js" defer></script>
</body>
</html>
